<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context="com.kumud.wellnessflow.ui.profile.ProfileActivity">

    <!-- Gradient Header Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/accent_bar_mood"
        android:alpha="0.6" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/profile_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        app:layout_scrollFlags="scroll|enterAlways"
        app:navigationContentDescription="@string/profile_toolbar_navigation"
        app:title="@string/profile_title"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profile_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/spacing_md"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_xl"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Profile Info Card with Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_info_card"
                style="@style/Widget.WellnessFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/accent_lemon"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/accent_teal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg"
                    android:gravity="center_horizontal">

                    <!-- Avatar Circle -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardBackgroundColor="@color/surface_card_tint"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            android:contentDescription="@string/profile_avatar_cd"
                            app:tint="@color/accent_indigo" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:textAlignment="center"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        tools:text="Hello, Jamie" />

                    <TextView
                        android:id="@+id/profile_member_since"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/text_secondary"
                        tools:text="Member since July 12" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bio Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_bio_card"
                style="@style/Widget.WellnessFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/divider_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/profile_bio_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/profile_bio_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/profile_bio_edit_button"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/profile_bio_edit"
                            app:backgroundTint="@color/surface_variant_light"
                            app:icon="@drawable/ic_edit_note"
                            app:iconTint="@color/primary_blue" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/profile_bio_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp"
                        android:visibility="gone"
                        tools:text="Mindfulness coach who loves sunrise journaling."
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/profile_bio_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/profile_bio_placeholder"
                        android:textColor="@color/text_subtle"
                        android:textSize="15sp"
                        android:lineSpacingExtra="2dp"
                        tools:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notes Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_notes_card"
                style="@style/Widget.WellnessFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/divider_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/profile_notes_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/profile_notes_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/profile_add_note_button"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/profile_notes_add"
                            android:text="@string/profile_notes_add"
                            android:textColor="@color/primary_blue"
                            app:backgroundTint="@color/surface_variant_light"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_add_note"
                            app:iconTint="@color/primary_blue" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/profile_notes_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mood Trend Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_mood_card"
                style="@style/Widget.WellnessFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Card Header with Icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/accent_bar_mood"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <TextView
                            android:id="@+id/profile_mood_title"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_mood_trend_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_mood"
                            android:contentDescription="@null"
                            android:padding="4dp"
                            android:background="@drawable/circle_icon_bg_lilac"
                            app:tint="@color/accent_lilac" />
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/profile_chart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:contentDescription="@string/profile_mood_trend_title"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/profile_notes_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/profile_notes_empty"
                            android:textColor="@color/text_subtle"
                            android:textSize="15sp"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </com.github.mikephil.charting.charts.LineChart>

                    <TextView
                        android:id="@+id/profile_chart_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center"
                        android:text="@string/profile_mood_trend_empty"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/text_subtle"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Weekly Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_summary_card"
                style="@style/Widget.WellnessFlow.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/accent_bar_summary"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <TextView
                            android:id="@+id/profile_summary_title"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_weekly_summary_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_chart"
                            android:contentDescription="@null"
                            android:padding="4dp"
                            android:background="@drawable/circle_icon_bg_teal"
                            app:tint="@color/accent_teal" />
                    </LinearLayout>

                    <!-- Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <!-- Habits Metric -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/profile_metric_habits"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardBackgroundColor="@color/surface_card_tint"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_md">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_habits"
                                    android:contentDescription="@null"
                                    app:tint="@color/accent_indigo" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/text_secondary"
                                    android:text="@string/nav_habits" />

                                <TextView
                                    android:id="@+id/profile_habits_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="sans-serif-medium"
                                    tools:text="12 / 21" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Hydration Metric -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/profile_metric_hydration"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="6dp"
                            app:cardBackgroundColor="@color/surface_card_tint"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_md">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_hydration"
                                    android:contentDescription="@null"
                                    app:tint="@color/accent_teal" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/text_secondary"
                                    android:text="@string/nav_hydration" />

                                <TextView
                                    android:id="@+id/profile_hydration_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="sans-serif-medium"
                                    tools:text="8500 ml" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Moods Metric -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/profile_metric_moods"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardBackgroundColor="@color/surface_card_tint"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="@dimen/spacing_md">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_mood"
                                    android:contentDescription="@null"
                                    app:tint="@color/accent_salmon" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                    android:textColor="@color/text_secondary"
                                    android:text="@string/nav_mood" />

                                <TextView
                                    android:id="@+id/profile_moods_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="sans-serif-medium"
                                    tools:text="8" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Card Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:clipToPadding="false"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="32dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_behavior="@string/hide_bottom_view_on_scroll_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_header_gradient"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="6dp"
            android:paddingBottom="8dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/profile_bottom_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:elevation="0dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                app:itemIconSize="24dp"
                app:itemIconTint="@color/selector_bottom_nav"
                app:itemRippleColor="@color/nav_item_ripple"
                app:itemTextColor="@color/selector_bottom_nav"
                app:itemActiveIndicatorStyle="@style/BottomNavActiveIndicator"
                app:labelVisibilityMode="labeled"
                app:menu="@menu/bottom_nav_menu" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>