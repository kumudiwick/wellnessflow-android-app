<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Reminder Toggle Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider_light"
            app:strokeWidth="1dp">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/reminder_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hydration_enable_label"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="20dp"
                app:thumbTint="@color/white"
                app:trackTint="@color/accent_teal"
                app:trackDecorationTint="@color/surface_variant_light" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Interval Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/interval_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/hydration_interval_label"
            app:boxBackgroundColor="@color/surface_card"
            app:boxStrokeColor="@color/accent_teal"
            app:boxStrokeWidth="2dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:hintTextColor="@color/accent_teal"
            app:endIconTint="@color/accent_teal"
            app:startIconDrawable="@android:drawable/ic_menu_recent_history"
            app:startIconTint="@color/accent_teal">

            <AutoCompleteTextView
                android:id="@+id/interval_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface_variant_light"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Start Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_day"
                        app:tint="@color/primary_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/hydration_start_time_label"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/start_time_button"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00"
                        android:textColor="@color/primary_blue"
                        app:backgroundTint="@color/surface_card_tint"
                        app:cornerRadius="12dp"
                        app:icon="@android:drawable/ic_menu_my_calendar"
                        app:iconTint="@color/primary_blue" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider_light" />

                <!-- End Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_lock_idle_alarm"
                        app:tint="@color/accent_indigo" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="@string/hydration_end_time_label"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/end_time_button"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20:00"
                        android:textColor="@color/accent_indigo"
                        app:backgroundTint="@color/surface_card_tint"
                        app:cornerRadius="12dp"
                        app:icon="@android:drawable/ic_menu_my_calendar"
                        app:iconTint="@color/accent_indigo" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Daily Goal -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/daily_goal_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/hydration_daily_goal_label"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="@color/surface_card"
            app:boxStrokeColor="@color/secondary_mint"
            app:boxStrokeWidth="2dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:hintTextColor="@color/secondary_mint"
            app:startIconDrawable="@android:drawable/ic_menu_compass"
            app:startIconTint="@color/secondary_mint"
            app:suffixText="ml"
            app:suffixTextColor="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/daily_goal_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="2000"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Active Days Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/active_days_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hydration_active_days_label"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:drawableStart="@android:drawable/ic_menu_week"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/accent_salmon" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/active_days_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp"
                    app:singleSelection="false">
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface_card_tint"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notification Settings"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:drawableStart="@android:drawable/ic_popup_reminder"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/accent_peach" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/sound_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hydration_notification_sound"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent_peach"
                    app:trackDecorationTint="@color/surface_variant_light" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/divider_light" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/vibrate_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hydration_notification_vibrate"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/accent_pink"
                    app:trackDecorationTint="@color/surface_variant_light" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>