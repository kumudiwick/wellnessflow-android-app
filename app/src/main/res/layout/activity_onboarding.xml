<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_surface_gradient"
    android:padding="@dimen/spacing_lg"
    tools:context=".ui.onboarding.OnboardingActivity">

    <!-- Decorative circles for visual interest -->
    <View
        android:id="@+id/decorative_circle_top"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp"
        android:background="@drawable/bg_home_day_card"
        android:alpha="0.4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/decorative_circle_bottom"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="-30dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/circle_decorative_sky"
        android:alpha="0.3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/onboarding_card"
        style="@style/Widget.WellnessFlow.Card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/divider_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Welcome Icon -->
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="@dimen/spacing_md"
                android:src="@drawable/ic_home"
                android:contentDescription="@string/onboarding_illustration_cd"
                app:tint="@color/primary_blue" />

            <TextView
                android:id="@+id/onboarding_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_title"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/onboarding_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/onboarding_subtitle"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/text_secondary" />

            <!-- Decorative divider -->
            <View
                android:layout_width="80dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@drawable/gradient_divider" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/onboarding_name_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:hint="@string/onboarding_name_hint"
                app:boxStrokeColor="@color/primary_blue"
                app:boxStrokeWidth="2dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:hintTextColor="@color/text_secondary"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primary_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/onboarding_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:paddingVertical="16dp"
                    tools:text="Sam" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/onboarding_continue"
                style="@style/Widget.Material3.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/onboarding_cta"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="16dp"
                app:elevation="4dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="end"
                app:iconTint="@android:color/white"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Illustration with shadow effect -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/illustration_container"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="@dimen/spacing_lg"
        app:cardBackgroundColor="@color/surface_card_tint"
        app:cardCornerRadius="90dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/onboarding_card">

        <ImageView
            android:id="@+id/onboarding_illustration"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:contentDescription="@string/onboarding_illustration_cd"
            android:src="@drawable/ic_home"
            app:tint="@color/accent_lilac" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Decorative dots pattern -->
    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/dots_pattern"
        android:alpha="0.2"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:tint="@color/accent_peach"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/illustration_container" />

</androidx.constraintlayout.widget.ConstraintLayout>